generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  draft
  pending_payment
  confirmed
  cancelled
  expired
}

enum PaymentStatus {
  pending
  paid
  expired
  failed
}

enum NotificationChannel {
  whatsapp
  email
}

enum NotificationStatus {
  queued
  sent
  failed
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String     @map("password_hash")
  roleId       String     @map("role_id")
  role         Role       @relation(fields: [roleId], references: [id])
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("users")
}

model Trip {
  id          String         @id @default(uuid())
  slug        String         @unique
  title       String
  description String
  location    String
  durationDay Int            @map("duration_day")
  basePrice   Decimal        @map("base_price") @db.Decimal(12, 2)
  coverImage  String?        @map("cover_image")
  isActive    Boolean        @default(true) @map("is_active")
  schedules   TripSchedule[]
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@index([slug])
  @@map("trips")
}

model TripSchedule {
  id          String    @id @default(uuid())
  tripId      String    @map("trip_id")
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  startDate   DateTime  @map("start_date") @db.Date
  endDate     DateTime  @map("end_date") @db.Date
  quota       Int
  bookedQuota Int       @default(0) @map("booked_quota")
  price       Decimal   @db.Decimal(12, 2)
  bookings    Booking[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([tripId, startDate])
  @@map("trip_schedules")
}

model Customer {
  id        String    @id @default(uuid())
  name      String
  whatsapp  String
  email     String?
  bookings  Booking[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([whatsapp, email])
  @@map("customers")
}

model Booking {
  id               String               @id @default(uuid())
  code             String               @unique
  customerId       String               @map("customer_id")
  customer         Customer             @relation(fields: [customerId], references: [id])
  scheduleId       String               @map("schedule_id")
  schedule         TripSchedule         @relation(fields: [scheduleId], references: [id])
  contactName      String               @map("contact_name")
  contactWhatsapp  String               @map("contact_whatsapp")
  contactEmail     String?              @map("contact_email")
  participantCount Int                  @map("participant_count")
  totalAmount      Decimal              @map("total_amount") @db.Decimal(12, 2)
  status           BookingStatus        @default(pending_payment)
  participants     BookingParticipant[]
  payment          Payment?
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  @@index([scheduleId, status])
  @@map("bookings")
}

model BookingParticipant {
  id        String   @id @default(uuid())
  bookingId String   @map("booking_id")
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  name      String
  whatsapp  String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("booking_participants")
}

model Payment {
  id                 String        @id @default(uuid())
  bookingId          String        @unique @map("booking_id")
  booking            Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider           String        @default("tripay")
  providerReference  String?       @unique @map("provider_reference")
  amount             Decimal       @db.Decimal(12, 2)
  status             PaymentStatus @default(pending)
  paymentUrl         String?       @map("payment_url")
  expiredAt          DateTime?     @map("expired_at")
  paidAt             DateTime?     @map("paid_at")
  rawCallbackPayload Json?         @map("raw_callback_payload")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  @@map("payments")
}

model NotificationLog {
  id          String              @id @default(uuid())
  channel     NotificationChannel
  recipient   String
  template    String
  payload     Json
  status      NotificationStatus  @default(queued)
  error       String?
  sentAt      DateTime?           @map("sent_at")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@index([channel, status])
  @@map("notification_logs")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([entity, entityId])
  @@map("audit_logs")
}
